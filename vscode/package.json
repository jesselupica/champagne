{
  "name": "champagne-scm",
  "displayName": "Champagne SCM",
  "description": "A universal, graphical source control interface for Git, Sapling, Graphite, and more",
  "version": "0.1.4",
  "publisher": "jesselupica",
  "license": "MIT",
  "engines": {
    "vscode": "^1.63.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:champagne.open-isl",
    "onWebviewPanel:champagne.isl",
    "onView:champagne.isl"
  ],
  "extensionKind": [
    "workspace"
  ],
  "galleryBanner": {
    "color": "#f5efe6",
    "theme": "light"
  },
  "main": "./dist/extension.js",
  "icon": "resources/extensionIcon.png",
  "homepage": "https://jesselupica.github.io/champagne/",
  "bugs": {
    "url": "https://github.com/jesselupica/champagne/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jesselupica/champagne"
  },
  "contributes": {
    "configuration": {
      "title": "Champagne",
      "properties": {
        "champagne.commandPath": {
          "type": "string",
          "default": "",
          "description": "%settings.commandPath.description%"
        },
        "champagne.showInlineBlame": {
          "type": "boolean",
          "description": "%settings.showInlineBlame.description%",
          "default": true
        },
        "champagne.showDiffComments": {
          "type": "boolean",
          "description": "%settings.showDiffComments.description%",
          "default": true
        },
        "champagne.inlineCommentDiffViewMode": {
          "type": "string",
          "enum": [
            "Unified",
            "Split"
          ],
          "description": "%settings.diffViewMode.description%",
          "default": "Unified"
        },
        "champagne.markConflictingFilesResolvedOnSave": {
          "type": "boolean",
          "description": "%settings.markConflictingFilesResolvedOnSave.description%",
          "default": true
        },
        "champagne.comparisonPanelMode": {
          "type": "string",
          "enum": [
            "Auto",
            "Always Separate Panel"
          ],
          "enumDescriptions": [
            "%settings.comparisonPanelMode.enumDescriptions.auto%",
            "%settings.comparisonPanelMode.enumDescriptions.always-separate-panel%"
          ],
          "description": "%settings.comparisonPanelMode.description%",
          "default": "Auto"
        },
        "champagne.isl.openBeside": {
          "type": "boolean",
          "default": false,
          "description": "%settings.isl.openBeside.description%"
        },
        "champagne.isl.showInSidebar": {
          "type": "boolean",
          "default": false,
          "description": "%settings.isl.showInSidebar.description%"
        },
        "champagne.isl.showOpenOrFocusButtonOnEditorTitle": {
          "type": "boolean",
          "default": true,
          "description": "%settings.isl.showOpenOrFocusButtonOnEditorTitle.description%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "champagne",
          "icon": "resources/champagne-viewContainer.svg",
          "title": "%champagne.command-category%"
        }
      ]
    },
    "views": {
      "champagne": [
        {
          "type": "webview",
          "id": "champagne.isl",
          "name": "%isl.title%",
          "when": "config.champagne.isl.showInSidebar"
        }
      ],
      "scm": [
        {
          "type": "webview",
          "id": "champagne.comments",
          "name": "Code Review Comments",
          "when": "isl.inlineCommentSidePanelEnabled"
        }
      ]
    },
    "commands": [
      {
        "command": "champagne.revert-file",
        "title": "%champagne.revert-file-command%",
        "category": "%champagne.command-category%",
        "icon": "$(discard)"
      },
      {
        "command": "champagne.open-isl",
        "title": "%champagne.open-isl-command%",
        "category": "%champagne.command-category%",
        "icon": "resources/champagne-favicon-light-green-transparent.svg"
      },
      {
        "command": "champagne.open-file-diff-uncommitted",
        "title": "%champagne.open-diff-uncommitted-command%",
        "category": "%champagne.command-category%",
        "icon": "$(git-pull-request-go-to-changes)"
      },
      {
        "command": "champagne.open-file-diff-head",
        "title": "%champagne.open-diff-head-command%",
        "category": "%champagne.command-category%"
      },
      {
        "command": "champagne.open-file-diff-stack",
        "title": "%champagne.open-diff-stack-command%",
        "category": "%champagne.command-category%"
      },
      {
        "command": "champagne.open-comparison-view-uncommitted",
        "title": "%champagne.open-comparison-view-uncommitted-command%",
        "category": "%champagne.command-category%"
      },
      {
        "command": "champagne.open-comparison-view-head",
        "title": "%champagne.open-comparison-view-head-command%",
        "category": "%champagne.command-category%"
      },
      {
        "command": "champagne.open-comparison-view-stack",
        "title": "%champagne.open-comparison-view-stack-command%",
        "category": "%champagne.command-category%"
      },
      {
        "command": "champagne.open-comparison-view",
        "title": "%champagne.open-comparison-view-command%",
        "when": false
      },
      {
        "command": "champagne.isl.focus",
        "title": "Focus Champagne Sidebar"
      },
      {
        "command": "champagne.open-remote-file-link",
        "title": "Open Current File in Code Review",
        "enablement": "champagne:hasRemoteLinkRepo"
      },
      {
        "command": "champagne.copy-remote-file-link",
        "title": "Copy Code Review Link for Current File",
        "enablement": "champagne:hasRemoteLinkRepo"
      },
      {
        "command": "champagne.open-comments",
        "title": "%champagne.open-comments-command%",
        "enablement": "isl.inlineCommentSidePanelEnabled"
      },
      {
        "command": "champagne.toggle-inline-comments",
        "title": "%champagne.toggle-inline-comments-command%",
        "enablement": "isl.inlineCommentSidePanelEnabled"
      },
      {
        "command": "champagne.debug.interpret-file-as-comments",
        "title": "Debug: Load File as Inline Code Review Comments (JSON)",
        "enablement": "champagne.isDev"
      }
    ],
    "keybindings": [
      {
        "command": "champagne.open-comparison-view-uncommitted",
        "key": "ctrl-'",
        "mac": "cmd-'",
        "when": "activeWebviewPanelId != 'champagne.isl'"
      },
      {
        "command": "champagne.open-comparison-view-head",
        "key": "ctrl-shift-'",
        "mac": "cmd-shift-'",
        "when": "activeWebviewPanelId != 'champagne.isl'"
      },
      {
        "command": "champagne.open-comments",
        "key": "alt-shift-g",
        "mac": "alt-shift-g",
        "when": "isl.inlineCommentSidePanelEnabled && activeWebviewPanelId != 'champagne.comments'"
      },
      {
        "command": "champagne.toggle-inline-comments",
        "key": "alt-shift-t",
        "mac": "alt-shift-t",
        "when": "isl.inlineCommentSidePanelEnabled"
      },
      {
        "command": "champagne.open-isl",
        "key": "ctrl-shift-i",
        "mac": "cmd-shift-i",
        "when": "isl.openInteractiveSmartlogShortcutEnabled"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "champagne.open-remote-file-link",
          "when": "champagne:hasRemoteLinkRepo"
        },
        {
          "command": "champagne.copy-remote-file-link",
          "when": "champagne:hasRemoteLinkRepo"
        }
      ],
      "editor/title": [
        {
          "command": "champagne.open-isl",
          "group": "navigation@-100",
          "when": "config.champagne.isl.showOpenOrFocusButtonOnEditorTitle && isl.showButtonOnEditorTitle"
        }
      ],
      "explorer/context": [
        {
          "command": "champagne.open-remote-file-link",
          "when": "champagne:hasRemoteLinkRepo && isFileSystemResource && resourceScheme =~ /^(?!output$|vscode-(?!remote|vfs$)).*$/"
        },
        {
          "command": "champagne.copy-remote-file-link",
          "when": "champagne:hasRemoteLinkRepo && isFileSystemResource && resourceScheme =~ /^(?!output$|vscode-(?!remote|vfs$)).*$/"
        }
      ],
      "commandPalette": [
        {
          "command": "champagne.isl.focus",
          "when": "config.champagne.isl.showInSidebar"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "champagne.open-file-diff-uncommitted",
          "group": "inline",
          "when": "scmProvider == champagne && scmResourceGroup == changes"
        },
        {
          "command": "champagne.revert-file",
          "group": "inline",
          "when": "scmProvider == champagne && scmResourceGroup == changes"
        }
      ],
      "scm/title": [
        {
          "command": "champagne.open-isl",
          "group": "navigation",
          "when": "scmProvider == champagne"
        }
      ]
    }
  },
  "scripts": {
    "eslint": "eslint extension webview --ext .ts --ext .tsx",
    "test": "jest",
    "watch-extension": "rollup --config rollup.extension.config.mjs --watch",
    "watch-webview": "vite",
    "build-extension": "rollup --config rollup.extension.config.mjs --environment NODE_ENV:production",
    "build-webview": "vite build",
    "vscode:prepublish": "node ./buildForPublish.js"
  },
  "optionalDependencies": {
    "vsce": "^2.15.0"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-replace": "^5.0.5",
    "@stylexjs/stylex": "^0.9.3",
    "@types/jest": "29.5.12",
    "@types/node": "^16.11.7",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.34.0",
    "cross-env": "7.0.3",
    "isl": "0.1.0",
    "jest": "29.7.0",
    "jotai": "^2.6.2",
    "mini-css-extract-plugin": "^2.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "29",
    "tsx": "^4.16.2",
    "typescript": "5.5.4",
    "vite": "5.4.12",
    "vite-plugin-stylex": "^0.10.1",
    "vscode-uri": "^3.0.6"
  }
}
